{
  "name": "liquichain-stack",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "bundle:docker": "docker build -t liquichain-chain:local -f apps/render-bundle/Dockerfile .",
    "web:export": "pnpm --filter web build",
    "chain": "anvil --host 127.0.0.1 --port 8545 --chain-id 31337",
    "deploy:mocks": "cd packages/contracts && forge script script/DeployMocks.s.sol:DeployMocks --rpc-url http://127.0.0.1:8545 --broadcast"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
