{
  "name": "@nfs/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "node ./scripts/copy-deployments.mjs",
    "build": "next build",
    "dev": "next dev -p 3000",
    "lint": "tsc --noEmit",
    "preview": "npx --yes serve@14 out -l 3000",
    "verify:routes": "node ./scripts/verify-routes.mjs",
    "test:e2e": "playwright test",
    "test:e2e:integration": "playwright test -c playwright.integration.config.ts",
    "pretest:e2e:integration": "pnpm run build",
    "start": "next start"
  },
  "dependencies": {
    "@nfs/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@tanstack/react-query": "^5.62.8",
    "next": "^15.1.3",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.21.54",
    "wagmi": "^2.14.4",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
